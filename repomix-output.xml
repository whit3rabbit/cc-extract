    return [
        f"Setup: {variant.variant_id}",
        f"Provider: {provider}",
        f"Claude Code: {version}",
        f"Health: {setup_health_status(state, variant.variant_id)}",
        f"Command: {paths.get('wrapper') or '(no command)'}",
